{
  "name": "untangle",
  "version": "0.0.1",
  "description": "MCP-native PR decomposer for AI-generated diffs. Splits tangled commits into reviewable stacked PRs.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "untangle": "./dist/cli.js",
    "untangle-mcp": "./dist/mcp.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/mcp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "vitest run tests/acceptance",
    "test:unit": "vitest run tests/unit",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "simple-git": "^3.25.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
