+import { describe, it, expect, vi } from 'vitest';
+import { exportUsers, validateExportOptions } from '../src/api/export';
+
+describe('exportUsers', () => {
+  it('returns CSV when format is csv', async () => {
+    const result = await exportUsers({ format: 'csv', includeHeaders: true });
+    expect(result).toContain(',');
+  });
+
+  it('returns JSON when format is json', async () => {
+    const result = await exportUsers({ format: 'json', includeHeaders: false });
+    expect(() => JSON.parse(result)).not.toThrow();
+  });
+});
+
+describe('validateExportOptions', () => {
+  it('accepts valid options', () => {
+    expect(validateExportOptions({ format: 'csv', includeHeaders: true })).toBe(true);
+  });
+
+  it('rejects invalid format', () => {
+    expect(validateExportOptions({ format: 'xml', includeHeaders: true })).toBe(false);
+  });
+
+  it('rejects non-object', () => {
+    expect(validateExportOptions('string')).toBe(false);
+    expect(validateExportOptions(null)).toBe(false);
+    expect(validateExportOptions(undefined)).toBe(false);
+  });
+});
