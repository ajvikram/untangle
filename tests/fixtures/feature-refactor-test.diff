+import { db } from '../db';
+import { serialize } from './serializer';
+
+export interface ExportOptions {
+  format: 'csv' | 'json';
+  includeHeaders: boolean;
+}
+
+export async function exportUsers(opts: ExportOptions): Promise<string> {
+  const users = await db.query('SELECT * FROM users');
+  return serialize(users, opts);
+}
+
+export async function exportOrders(opts: ExportOptions): Promise<string> {
+  const orders = await db.query('SELECT * FROM orders');
+  return serialize(orders, opts);
+}
+
+export function validateExportOptions(opts: unknown): opts is ExportOptions {
+  if (typeof opts !== 'object' || opts === null) return false;
+  const o = opts as Record<string, unknown>;
+  return (
+    (o.format === 'csv' || o.format === 'json') &&
+    typeof o.includeHeaders === 'boolean'
+  );
+}
+
+export class ExportError extends Error {
+  constructor(
+    message: string,
+    public readonly code: string,
+  ) {
+    super(message);
+    this.name = 'ExportError';
+  }
+}
+
+export const EXPORT_FORMATS = ['csv', 'json'] as const;
+export type ExportFormat = (typeof EXPORT_FORMATS)[number];
+
+export const MAX_EXPORT_ROWS = 10_000;
diff --git a/src/api/serializer.ts b/src/api/serializer.ts
index 1111111..2222222 100644
--- a/src/api/serializer.ts
+++ b/src/api/serializer.ts
@@ -1,20 +1,25 @@
-export function serialize(data: unknown[]): string {
-  return JSON.stringify(data);
+import type { ExportOptions } from './export';
+
+export function serialize(data: unknown[], opts: ExportOptions): string {
+  if (opts.format === 'csv') {
+    return serializeCsv(data, opts.includeHeaders);
+  }
+  return JSON.stringify(data, null, 2);
+}
+
+function serializeCsv(data: unknown[], includeHeaders: boolean): string {
+  if (data.length === 0) return '';
+  const keys = Object.keys(data[0] as Record<string, unknown>);
+  const rows: string[] = [];
+  if (includeHeaders) {
+    rows.push(keys.join(','));
+  }
+  for (const item of data) {
+    const record = item as Record<string, unknown>;
+    rows.push(keys.map((k) => String(record[k] ?? '')).join(','));
+  }
+  return rows.join('\n');
 }
